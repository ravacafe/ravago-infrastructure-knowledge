        <mxCell id="SGVVF2tzGZEMksEP0Lrv-1" value="&lt;h1 style=&quot;border-color: var(--border-color);&quot;&gt;&lt;font style=&quot;font-size: 31px;&quot;&gt;SFTP - Azure Blob Storage - Design Choices&lt;/font&gt;&lt;/h1&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;div style=&quot;font-size: 19px;&quot;&gt;&lt;ul&gt;&lt;li&gt;Azure Blob Storage containers will be using Storage Account local SFTP users (No-AAD Integration)&lt;/li&gt;&lt;li&gt;SFTP Authentication, SSH password or SSHkey pair are supported&lt;/li&gt;&lt;li&gt;Ingress for External party will be limited based on their IPv4 Address&lt;/li&gt;&lt;li&gt;Permissions are to be granted on the Container level, no granular folder permissions are supported.&lt;/li&gt;&lt;li&gt;SFTP is only supported&lt;/li&gt;&lt;li&gt;Private Endpoint will be deployed, so Ravago Backend System can access the SFTP shares over a private endpoint.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;dashed=1;" parent="lI2iOjNpyglTklKt2sLQ-1" vertex="1">
